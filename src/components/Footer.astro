---
import home from '@/data/spawn-home.json';
import TrustIndicators from '@/components/TrustIndicators.astro';

const b = home.brand;
const dmeta = (home as { defaultMetaDescription?: string }).defaultMetaDescription || b.taglineShort;
const year = new Date().getFullYear();
---

<footer class="mt-20 pb-8">
  <div class="max-w-site mx-auto px-4 sm:px-5">
    <div class="bg-white rounded-3xl shadow-soft border border-cream-200 px-6 md:px-10 py-12 md:py-14">
      <div class="mb-8">
        <TrustIndicators />
      </div>

      <div class="grid md:grid-cols-3 gap-10 md:gap-8 text-sm text-ink-700">
        <div>
          <p class="font-display text-2xl text-ink-900 mb-3">{b.fullName}</p>
          <p class="leading-relaxed text-ink-600">
            {dmeta}
          </p>
        </div>
        <div>
          <p class="font-semibold mb-3 text-ink-900 uppercase tracking-[0.15em] text-xs">Read</p>
          <ul class="space-y-2">
            <li><a href="/pillars" class="hover:text-terracotta-600 no-underline cursor-pointer">Guides</a></li>
            <li><a href="/products" class="hover:text-terracotta-600 no-underline cursor-pointer">Product reviews</a></li>
            <li><a href="/articles" class="hover:text-terracotta-600 no-underline cursor-pointer">Articles</a></li>
          </ul>
        </div>
        <div>
          <p class="font-semibold mb-3 text-ink-900 uppercase tracking-[0.15em] text-xs">About</p>
          <ul class="space-y-2">
            <li><a href="/about" class="hover:text-terracotta-600 no-underline cursor-pointer">About us</a></li>
            <li><a href="/methodology/" class="hover:text-terracotta-600 no-underline cursor-pointer">Methodology</a></li>
            <li><a href="/disclosure/" class="hover:text-terracotta-600 no-underline cursor-pointer">Affiliate disclosure</a></li>
            <li><a href="/privacy/" class="hover:text-terracotta-600 no-underline cursor-pointer">Privacy</a></li>
            <li><a href="/terms/" class="hover:text-terracotta-600 no-underline cursor-pointer">Terms</a></li>
            <li><a href="/contact/" class="hover:text-terracotta-600 no-underline cursor-pointer">Contact</a></li>
          </ul>
        </div>
      </div>

      <div class="mt-10 pt-6 border-t border-cream-200 text-center text-xs text-ink-500">
        &copy; {year} {b.fullName}. We may earn a commission from qualifying purchases.
      </div>
    </div>
  </div>
</footer>
