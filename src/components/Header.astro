---
import BrandMark from '@/components/BrandMark.astro';
import home from '@/data/spawn-home.json';

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/pillars', label: 'Guides' },
  { href: '/products', label: 'Reviews' },
  { href: '/articles', label: 'Articles' },
  { href: '/about', label: 'About' },
];

const ctaHref = home.homepage?.ctaPrimaryHref || '/products';
const ctaLabel = home.homepage?.ctaPrimaryLabel || 'See pricing report';
---

<header class="sticky top-0 z-40 bg-cream-50/90 backdrop-blur-md border-b border-cream-200/80">
  <div class="max-w-site mx-auto px-4 sm:px-5 pt-3 sm:pt-4 pb-3">
    <div
      id="site-nav-shell"
      class="bg-white/90 backdrop-blur-sm rounded-2xl md:rounded-full shadow-soft border border-cream-200/80 transition-shadow duration-200"
    >
      <div class="px-4 sm:px-6 py-3 md:py-3.5 flex items-center justify-between gap-3">
        <a href="/" class="no-underline flex items-baseline min-w-0 shrink cursor-pointer" aria-label="InkLedger home">
          <BrandMark splitWordmark />
        </a>

        <nav class="hidden md:block" aria-label="Primary">
          <ul class="flex gap-4 lg:gap-6 text-sm font-medium">
            {navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-ink-700 hover:text-terracotta-600 no-underline transition-colors duration-200 cursor-pointer"
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <div class="flex items-center gap-2 shrink-0">
          <a href={ctaHref} class="btn-nav-cta no-underline">
            {ctaLabel}
          </a>

          <button
            id="site-nav-toggle"
            type="button"
            aria-label="Open menu"
            aria-expanded="false"
            aria-controls="site-nav-mobile"
            class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded-full bg-cream-50 text-ink-900 border border-cream-200
                   hover:bg-white transition-colors duration-200 shrink-0 cursor-pointer"
          >
            <svg class="w-5 h-5 icon-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <line x1="4" y1="7" x2="20" y2="7" />
              <line x1="4" y1="12" x2="20" y2="12" />
              <line x1="4" y1="17" x2="20" y2="17" />
            </svg>
            <svg class="w-5 h-5 icon-close hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <line x1="6" y1="6" x2="18" y2="18" />
              <line x1="18" y1="6" x2="6" y2="18" />
            </svg>
          </button>
        </div>
      </div>

      <nav
        id="site-nav-mobile"
        class="md:hidden overflow-hidden max-h-0 transition-[max-height] duration-300 ease-out"
        aria-hidden="true"
        aria-label="Mobile primary"
      >
        <ul class="px-4 pb-4 pt-1 space-y-1 text-base font-medium border-t border-cream-200/80">
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="block px-4 py-3 rounded-xl text-ink-700 hover:bg-cream-50 hover:text-terracotta-600 no-underline transition-colors duration-200 cursor-pointer"
              >
                {item.label}
              </a>
            </li>
          ))}
          <li class="pt-2">
            <a href={ctaHref} class="btn-primary w-full text-sm no-underline">
              {ctaLabel}
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</header>

<script>
  (function () {
    const toggle = document.getElementById('site-nav-toggle');
    const panel  = document.getElementById('site-nav-mobile');
    if (!toggle || !panel) return;

    const iconOpen  = toggle.querySelector('.icon-open');
    const iconClose = toggle.querySelector('.icon-close');

    function setOpen(open) {
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      panel.setAttribute('aria-hidden', open ? 'false' : 'true');
      if (open) {
        panel.style.maxHeight = panel.scrollHeight + 'px';
        iconOpen?.classList.add('hidden');
        iconClose?.classList.remove('hidden');
      } else {
        panel.style.maxHeight = '0px';
        iconOpen?.classList.remove('hidden');
        iconClose?.classList.add('hidden');
      }
    }

    toggle.addEventListener('click', function () {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      setOpen(!isOpen);
    });

    panel.addEventListener('click', function (e) {
      const target = e.target;
      if (target && target.closest('a')) {
        setOpen(false);
      }
    });

    const mq = window.matchMedia('(min-width: 768px)');
    function handleMQ() {
      if (mq.matches) setOpen(false);
    }
    mq.addEventListener ? mq.addEventListener('change', handleMQ) : mq.addListener(handleMQ);
  })();
</script>
