---
// src/components/AffiliateDisclosure.astro
export interface Props {
  variant?: 'banner' | 'inline';
}
const { variant = 'banner' } = Astro.props;
---
<aside
  class:list={[
    'not-prose flex gap-3 items-start rounded-lg p-3 mb-6 text-xs leading-relaxed',
    'bg-gray-50 dark:bg-gray-800 border-l-4 border-accent',
    variant === 'inline' ? 'my-4' : '',
  ]}
  role="note"
  aria-label="Affiliate disclosure"
>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0 mt-0.5 text-accent" aria-hidden="true">
    <path fill-rule="evenodd" d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0Zm-7-4a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM9 9a.75.75 0 0 0 0 1.5h.253a.25.25 0 0 1 .244.304l-.459 2.066A1.75 1.75 0 0 0 10.747 15H11a.75.75 0 0 0 0-1.5h-.253a.25.25 0 0 1-.244-.304l.459-2.066A1.75 1.75 0 0 0 9.253 9H9Z" clip-rule="evenodd" />
  </svg>
  <p class="text-ink-700 dark:text-gray-300 m-0">
    <strong class="font-semibold">Disclosure:</strong> This article contains affiliate links.
    If you purchase through our links, we may earn a small commission at no extra cost to you.
    We only recommend products we&apos;ve researched and believe provide value.{' '}
    <a href="/disclosure" class="underline underline-offset-4 hover:no-underline">Learn more.</a>
  </p>
</aside>
