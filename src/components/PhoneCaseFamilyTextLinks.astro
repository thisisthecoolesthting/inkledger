---
/**
 * Footer family-of-brands phone-case cross-promo - now a runtime ad slot.
 * MIGRATION: old version had const aff = 'inkledger-20' hardcoded.
 * New version emits [data-ad-slot="footer-family"] div filled by inject.js.
 */
import { CASE_AD_STORES } from '@/data/case-ad-stores';
import home from '@/data/spawn-home.json';

export interface Props {
  placement?: string;
  compact?: boolean;
}

const { placement = 'footer-family', compact = false } = Astro.props;

const rawBrandName: string =
  (home as { brand?: { shortName?: string; fullName?: string } }).brand?.shortName ||
  (home as { brand?: { fullName?: string } }).brand?.fullName ||
  (home as { siteSlug?: string }).siteSlug ||
  'inkledger';
const ssrSlug = rawBrandName.toLowerCase().replace(/[^a-z0-9-]/g, '');

const fallbackStore = CASE_AD_STORES[0];
const fallbackHref = `https://${fallbackStore.domain}/?utm_source=${ssrSlug}&utm_medium=cross_promo_text&utm_campaign=15off&utm_content=${placement}_${fallbackStore.slug}`;
---

<div
  data-ad-slot="footer-family"
  class:list={[
    'not-prose rounded-2xl border border-cream-200 bg-cream-50/80',
    compact ? 'px-3 py-3 text-xs' : 'px-4 py-4 sm:px-5 sm:py-5 text-sm',
  ]}
  aria-label="Sponsored: phone case shops in our family of brands"
>
  <p class="font-mono text-[10px] tracking-[0.14em] uppercase text-terracotta-600 mb-3 !m-0">
    From our family of brands
  </p>
  <a
    href={fallbackHref}
    class="font-semibold text-ink-900 hover:text-terracotta-600 no-underline transition-colors"
    rel="noopener sponsored"
    target="_blank"
  >
    {fallbackStore.name}
  </a>
  <span class="text-ink-500"> - </span>
  <span class="text-ink-700 leading-snug">
    {fallbackStore.tagline} {fallbackStore.offer}; code <span class="font-mono text-[11px]">{fallbackStore.code}</span>.
  </span>
</div>
