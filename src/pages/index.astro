        <p class="text-cream-50/80 text-base md:text-lg leading-relaxed mt-5 max-w-[56ch]">{aboutBody}</p>
        <div class="flex flex-wrap gap-3 mt-9">
          <a href="/methodology/" class="btn-primary no-underline cursor-pointer">
