---
// INKLEDGER HOMEPAGE v2 — Analytical Watchdog Template
// Sections: Hero → Trust Strip → Data Stats → Pillars → Articles (6) → Products → About → Newsletter → Methodology
// Uses CompliantLayout (available in inkledger). Data from spawn-home.json.

import CompliantLayout from '@/layouts/CompliantLayout.astro';
import { getCollection } from 'astro:content';
import ProductCard from '@/components/ProductCard.astro';
import NewsletterForm from '@/components/NewsletterForm.astro';
import TrustIndicators from '@/components/TrustIndicators.astro';
import HeroSnapshot from '@/components/HeroSnapshot.astro';
import home from '@/data/spawn-home.json';

const h = home.homepage;
const b = home.brand;
const homeX = home as Record<string, any>;
const dmeta = homeX.defaultMetaDescription || b.taglineShort || '';
const authorSlug = homeX.defaultAuthorSlug || '_default';
const editorPseudonym = homeX.persona?.pseudonymHint || homeX.persona?.name || 'Editorial';
const aboutHeadline = homeX.about?.headline || `Why ${b.shortName} exists`;
const aboutBody = homeX.about?.body || (b as any).taglineLong || '';
const heroCategories: string[] = Array.isArray(homeX.categories) ? homeX.categories : [];

const allProducts = await getCollection('products', ({ data }) => data.status === 'published');
const completeProducts = allProducts.filter((p) => {
  const d = p.data;
  const hasImage = d.imageUrl && !d.imageUrl.includes('example') && !d.imageUrl.startsWith('data:');
  const hasPrice = typeof d.price === 'number' && d.price > 0;
  const hasRating = typeof d.rating === 'number' && d.rating > 0;
  return hasImage && hasPrice && hasRating;
});
const compareRow = completeProducts.sort((a, b) => (b.data.score ?? 0) - (a.data.score ?? 0)).slice(0, 3);

const allPillars = await getCollection('pillars', ({ data }) => data.status === 'published');
const pillarFour = allPillars.sort((a, b) => +new Date(b.data.publishedAt) - +new Date(a.data.publishedAt)).slice(0, 4);

const allArticles = await getCollection('articles', ({ data }) => data.status === 'published');

// ── Topic dedup: one article per primary tag, newest wins ──────────────────
const articlesByDateDesc = [...allArticles].sort((a, b) => +new Date(b.data.publishedAt) - +new Date(a.data.publishedAt));
const seenTopicKeys = new Set<string>();
const topicUnique: typeof articlesByDateDesc = [];
const topicSpillover: typeof articlesByDateDesc = [];
for (const a of articlesByDateDesc) {
  const key = String((a.data.tags?.[0] || '')).toLowerCase().trim() || `__slug-${a.slug}`;
  if (!seenTopicKeys.has(key)) { seenTopicKeys.add(key); topicUnique.push(a); }
  else topicSpillover.push(a);
}
const latestSix = topicUnique.length >= 3 ? topicUnique.slice(0, 6) : [...topicUnique, ...topicSpillover].slice(0, 6);

// ── Niche image pool — office / printer / cost / ink ──────────────────────
const NICHE_IMAGE_POOL = [
  'https://images.unsplash.com/photo-1588196749597-9ff075ee6b5b?auto=format&fit=crop&w=1200&q=80',
  'https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=1200&q=80',
  'https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?auto=format&fit=crop&w=1200&q=80',
  'https://images.unsplash.com/photo-1607082348824-0a96f2a4b9da?auto=format&fit=crop&w=1200&q=80',
  'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&w=1200&q=80',
  'https://images.unsplash.com/photo-1563986768494-4dee2763ff3f?auto=format&fit=crop&w=1200&q=80',
  'https://images.unsplash.com/photo-1542744095-fcf48d80b0fd?auto=format&fit=crop&w=1200&q=80',
  'https://images.unsplash.com/photo-1556761175-5973dc0f32e7?auto=format&fit=crop&w=1200&q=80',
  'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=1200&q=80',
  'https://images.unsplash.com/photo-1579548122080-c35fd6820ecb?auto=format&fit=crop&w=1200&q=80',
];

const normalizeKey = (u: string | undefined | null): string => {
  if (!u) return '';
  const m = String(u).match(/photo-[^?]+/);
  return m ? m[0] : String(u).split('?')[0];
};
const heroKey = normalizeKey(h.heroImageUrl);
const articleKeyCounts = new Map<string, number>();
for (const a of latestSix) {
  const k = normalizeKey(a.data.heroImage); if (k) articleKeyCounts.set(k, (articleKeyCounts.get(k) || 0) + 1);
}
const usedKeys = new Set<string>();
if (heroKey) usedKeys.add(heroKey);

const hashSlug = (slug: string) => {
  let h = 0;
  for (let i = 0; i < slug.length; i++) h = ((h << 5) - h + slug.charCodeAt(i)) | 0;
  return Math.abs(h);
};
const pickPoolImage = (slug: string): string => {
  const start = hashSlug(slug) % NICHE_IMAGE_POOL.length;
  for (let i = 0; i < NICHE_IMAGE_POOL.length; i++) {
    const c = NICHE_IMAGE_POOL[(start + i) % NICHE_IMAGE_POOL.length];
    const k = normalizeKey(c);
    if (!usedKeys.has(k)) { usedKeys.add(k); return c; }
  }
  return NICHE_IMAGE_POOL[start];
};
const latestSixWithImages = latestSix.map((a) => {
  const k = normalizeKey(a.data.heroImage);
  const isShared = k && (articleKeyCounts.get(k) || 0) > 1;
  if (k && !isShared && !usedKeys.has(k)) { usedKeys.add(k); return { entry: a, imageUrl: a.data.heroImage as string }; }
  return { entry: a, imageUrl: pickPoolImage(a.slug) };
});

// ── Top-18 articles for tag filter ────────────────────────────────────────────
const top18IL = articlesByDateDesc.slice(0, 18);
const extraArticlesIL = top18IL.slice(6).map((a) => ({ entry: a, imageUrl: pickPoolImage(a.slug) }));

// ── Top tags ──────────────────────────────────────────────────────────────────
const tagCountsIL = new Map<string, number>();
for (const a of allArticles) {
  for (const tag of (a.data.tags ?? [])) {
    tagCountsIL.set(tag, (tagCountsIL.get(tag) || 0) + 1);
  }
}
const topTagsIL = [...tagCountsIL.entries()]
  .sort((a, b) => b[1] - a[1])
  .filter(([t]) => tagCountsIL.get(t)! < allArticles.length * 0.9)
  .slice(0, 7)
  .map(([tag]) => tag);

const trustLineDisplay = (h.trustLine && String(h.trustLine).trim()) || 'No sponsorship from printer manufacturers. Partner revenue on third-party refills and compatibles only.';

const dataStats = [
  { num: '43%', label: 'OEM price increase', sub: 'Across HP, Epson, Brother, Canon since 2019.' },
  { num: '$284', label: 'avg household loss', sub: 'Per year on overpriced OEM cartridges.' },
  { num: '126+', label: 'cartridge models', sub: 'Tracked, compared, and independently rated.' },
];

const socialProof = [
  {
    quote: 'We re-price every cartridge listing every Monday. If the number moved, the article gets a date stamp.',
    role: 'Research protocol',
  },
  {
    quote: 'Compatible picks earn a score only after a 200-page mixed print test — not a spec-sheet guess.',
    role: 'Lab testing',
  },
  {
    quote: 'No Epson, HP, Brother, or Canon sponsorships. Affiliate links are third-party refills we would buy.',
    role: 'Editorial independence',
  },
];
---

<CompliantLayout title={b.fullName} description={dmeta}>

  {/* ════ 1. HERO — compact, readable above the fold ════ */}
  <section class="hero-band pt-6 md:pt-8 pb-10 md:pb-12">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10
         bg-[radial-gradient(50%_80%_at_100%_0%,rgba(245,158,11,.14),transparent_55%),radial-gradient(40%_50%_at_0%_100%,rgba(30,58,138,.22),transparent_60%)]"></div>
    <div class="max-w-site mx-auto px-4 sm:px-5">
      <div class="grid lg:grid-cols-[1fr_380px] xl:grid-cols-[1fr_420px] gap-8 lg:gap-10 items-start">
        <div class="min-w-0">
          <p class="section-eyebrow text-terracotta-400 mb-2">
            {h.eyebrow}
          </p>
          <h1 class="font-display text-3xl sm:text-4xl lg:text-[2.75rem] text-cream-50 leading-[1.1] tracking-tight text-balance">
            {h.h1}
          </h1>
          <p class="text-base text-cream-50/85 max-w-[36em] mt-4 leading-relaxed">
            {h.subhead}
          </p>
          <div class="flex flex-wrap gap-3 mt-6">
            <a href={h.ctaPrimaryHref} class="btn-primary no-underline cursor-pointer text-sm md:text-base">
              {h.ctaPrimaryLabel}
              <svg class="w-4 h-4 ml-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
            <a href={h.ctaSecondaryHref} class="btn-secondary no-underline cursor-pointer text-sm md:text-base">
              {h.ctaSecondaryLabel}
            </a>
          </div>
          <ul class="flex flex-wrap gap-x-5 gap-y-2 mt-5 text-sm text-cream-50/75" role="list">
            {['No OEM sponsorships', 'Weekly price checks', `${allArticles.length}+ articles`].map((t) => (
              <li class="flex items-center gap-1.5">
                <svg class="w-4 h-4 text-terracotta-400 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                {t}
              </li>
            ))}
          </ul>
        </div>

        <HeroSnapshot stats={dataStats} products={compareRow} articleCount={allArticles.length} />
      </div>
    </div>
  </section>

  {/* ════ 2. TRUST STRIP + indicators ════ */}
  <section class="border-y border-cream-200 bg-white" aria-labelledby="trust-strip-heading">
    <div class="max-w-site mx-auto px-4 sm:px-5 py-5 md:py-6">
      <div class="mb-4">
        <TrustIndicators />
      </div>
      <div class="grid md:grid-cols-[auto_1fr_auto] gap-4 md:gap-8 items-center">
      <p id="trust-strip-heading" class="section-eyebrow whitespace-nowrap">Editorial standards</p>
      <blockquote class="font-display italic text-base md:text-lg text-ink-700 leading-snug border-0 m-0 p-0">
        "{trustLineDisplay}"
      </blockquote>
      <a href="/methodology/" class="font-mono text-[11.5px] tracking-[0.08em] uppercase text-ink-900 border-b-2 border-terracotta-500 pb-0.5 whitespace-nowrap no-underline hover:text-terracotta-600 cursor-pointer">
        How we work
        <span class="sr-only"> — read our methodology</span>
      </a>
      </div>
    </div>
  </section>

  {/* ════ 2b. SOCIAL PROOF — editorial credibility (ui-ux-pro-max landing pattern) ════ */}
  <section class="bg-cream-50 border-b border-cream-200" aria-labelledby="social-proof-heading">
    <div class="max-w-site mx-auto px-4 sm:px-5 py-12 md:py-16">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-8">
        <div>
          <p class="section-eyebrow mb-2">Why readers trust us</p>
          <h2 id="social-proof-heading" class="font-display text-3xl md:text-4xl text-ink-900 !mt-0 leading-tight max-w-[20ch]">
            Investigative standards, not affiliate fluff.
          </h2>
        </div>
        <p class="text-sm text-ink-600 max-w-[32ch]">
          {allArticles.length}+ published articles · weekly price checks · transparent methodology
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-4">
        {socialProof.map((item) => (
          <figure class="card-soft p-6 h-full flex flex-col cursor-default hover:translate-y-0">
            <svg class="w-8 h-8 text-terracotta-500 mb-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179Zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179Z" />
            </svg>
            <blockquote class="text-ink-700 text-sm leading-relaxed flex-1 m-0">
              "{item.quote}"
            </blockquote>
            <figcaption class="mt-4 font-mono text-[10px] tracking-[0.14em] uppercase text-terracotta-600">
              {item.role}
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  {/* ════ 3. PILLAR GRID ════ */}
  {(pillarFour.length > 0 || heroCategories.length > 0) && (
    <section class="max-w-6xl mx-auto px-5 py-8 md:py-12">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-5 mb-10">
        <div>
          <p class="font-mono text-[11px] tracking-[0.18em] uppercase text-terracotta-600 font-medium mb-2">Start here</p>
          <h2 class="font-display text-3xl md:text-4xl text-ink-900 leading-tight !mt-0 max-w-[18ch]">
            Pillars we track every week.
          </h2>
        </div>
        <p class="text-sm text-ink-700 max-w-[28ch]">
          Explainer → tracked models → cheaper alternative. Three clicks to the answer.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {(pillarFour.length >= 4 ? pillarFour : heroCategories.slice(0, 4)).map((entry: any, idx: number) => {
          const isPillar = !!entry?.slug && !!entry?.data;
          const tints = [
            'bg-gradient-to-b from-cream-100 to-cream-50',
            'bg-gradient-to-b from-blue-50 to-cream-50',
            'bg-gradient-to-b from-terracotta-400/10 to-cream-50',
            'bg-gradient-to-b from-cream-200 to-cream-50',
          ];
          const num = String(idx + 1).padStart(2, '0');
          const title = isPillar ? entry.data.title : String(entry).charAt(0).toUpperCase() + String(entry).slice(1);
          const excerpt = isPillar ? entry.data.excerpt : `Tracked models and price history for ${entry}.`;
          const href = isPillar ? `/pillars/${entry.slug}` : `/articles?cat=${entry}`;
          const firstWord = String(entry?.data?.title || entry || '').split(' ')[0];
          return (
            <a href={href} class={`group no-underline relative overflow-hidden rounded-xl border border-cream-200 p-6 min-h-[240px] flex flex-col transition-all duration-200 hover:shadow-soft-lg hover:border-terracotta-400 cursor-pointer ${tints[idx % tints.length]}`}>
              <p class="font-display text-sm text-terracotta-600">{num} · {firstWord}</p>
              <h3 class="font-display text-xl text-ink-900 !mt-2 leading-snug max-w-[14ch]">{title}</h3>
              <p class="text-sm text-ink-700 mt-2.5 leading-relaxed">{excerpt}</p>
              <span class="font-mono text-[11px] tracking-[0.1em] uppercase text-ink-900 mt-auto pt-4 group-hover:text-terracotta-600">
                Explore <span class="text-terracotta-500">→</span>
              </span>
            </a>
          );
        })}
      </div>
    </section>
  )}

  {/* ════ 5. LATEST ARTICLES + TAG FILTER ════ */}
  {latestSixWithImages.length > 0 && (
    <section class="bg-gradient-to-b from-cream-50 to-cream-100 border-y border-cream-200">
      <div class="max-w-6xl mx-auto px-5 py-20">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-5 mb-6">
          <div>
            <p class="font-mono text-[11px] tracking-[0.18em] uppercase text-terracotta-600 font-medium mb-2">Latest from the desk</p>
            <h2 class="font-display text-3xl md:text-4xl text-ink-900 !mt-0 leading-tight max-w-[20ch]">
              Recently published.
              <span class="ml-3 font-mono text-base font-normal text-ink-400 align-middle">{allArticles.length}</span>
            </h2>
          </div>
          <a href="/articles" class="font-mono text-[11.5px] tracking-[0.08em] uppercase text-ink-900 border-b border-terracotta-500 pb-0.5 no-underline hover:text-terracotta-600 whitespace-nowrap">
            All articles →
          </a>
        </div>

        {/* — tag filter strip — */}
        {topTagsIL.length > 0 && (
          <div id="il-tag-strip" class="flex flex-wrap gap-2 mb-8">
            <button data-filter="all"
              class="il-pill il-pill-active font-mono text-[10px] tracking-[0.12em] uppercase px-3.5 py-1.5 rounded-full border transition-all duration-200">
              All
            </button>
            {topTagsIL.map((tag) => (
              <button data-filter={tag}
                class="il-pill font-mono text-[10px] tracking-[0.12em] uppercase px-3.5 py-1.5 rounded-full border transition-all duration-200">
                {tag}
              </button>
            ))}
          </div>
        )}

        <div id="il-article-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {[...latestSixWithImages, ...extraArticlesIL].map(({ entry: a, imageUrl }, i) => (
            <a href={`/articles/${a.slug}`}
               data-tags={(a.data.tags ?? []).join(',')}
               data-latest={i < 6 ? 'true' : 'false'}
               class={`il-article-card group no-underline block bg-white border border-cream-200 rounded-xl overflow-hidden hover:shadow-soft-lg hover:border-terracotta-400 transition-all duration-200 cursor-pointer${i >= 6 ? ' hidden' : ''}`}>
              <div class="relative aspect-[2/3] overflow-hidden bg-cream-100">
                <img src={imageUrl} alt={a.data.title} loading="lazy"
                     class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-500" />
                <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-b from-transparent via-ink-900/85 to-ink-900/60"></div>
                <div class="absolute inset-x-0 bottom-0 p-5 text-cream-50">
                  <span class="font-mono text-[10.5px] tracking-[0.16em] uppercase text-cream-50/85">
                    {(a.data.tags?.[0] || 'Article')} · {a.data.readingTime || '8'} min read
                  </span>
                  <h3 class="font-display text-xl leading-[1.12] !mt-1 text-cream-50 max-w-[14ch]">{a.data.title}</h3>
                </div>
              </div>
              <div class="px-5 py-3 flex items-center gap-2.5 text-xs text-ink-500 border-t border-cream-200">
                <span class="inline-grid place-items-center w-6 h-6 rounded-full bg-blue-900 text-cream-50 font-display font-semibold text-[11px]">
                  {(editorPseudonym?.[0] || 'I').toUpperCase()}
                </span>
                <span>{editorPseudonym || 'Editorial'} · {new Date(a.data.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
              </div>
            </a>
          ))}
        </div>

        {/* — browse all CTA — */}
        <div class="mt-10 pt-8 border-t border-cream-200 flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="text-sm text-ink-500">{allArticles.length} articles published · updated weekly</p>
          <a href="/articles" class="btn-primary no-underline">
            Browse all {allArticles.length} articles →
          </a>
        </div>

        <style>{`
          .il-pill { background: white; border-color: #dde3ef; color: #4a5568; }
          .il-pill:hover { border-color: #1e3a8a; color: #1e3a8a; }
          .il-pill-active { background: #1e3a8a; border-color: #1e3a8a; color: white; }
        `}</style>
        <script>{`
          (function() {
            const strip = document.getElementById('il-tag-strip');
            if (!strip) return;
            const cards = document.querySelectorAll('.il-article-card');
            strip.addEventListener('click', function(e) {
              const btn = e.target.closest('[data-filter]');
              if (!btn) return;
              const tag = btn.getAttribute('data-filter');
              strip.querySelectorAll('.il-pill').forEach(p => p.classList.remove('il-pill-active'));
              btn.classList.add('il-pill-active');
              let shown = 0;
              cards.forEach(function(card) {
                const tags = (card.getAttribute('data-tags') || '').split(',');
                const isLatest = card.getAttribute('data-latest') === 'true';
                const matches = tag === 'all' ? isLatest : tags.includes(tag);
                if (matches && shown < 9) { card.classList.remove('hidden'); shown++; }
                else { card.classList.add('hidden'); }
              });
            });
          })();
        `}</script>
      </div>
    </section>
  )}

  {/* ════ 6. PRODUCT COMPARISON ════ */}
  {compareRow.length >= 1 && (
    <section class="max-w-6xl mx-auto px-5 py-20">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-5 mb-8">
        <div>
          <p class="font-mono text-[11px] tracking-[0.18em] uppercase text-terracotta-600 font-medium mb-2">Tracked this week</p>
          <h2 class="font-display text-3xl md:text-4xl text-ink-900 !mt-0 leading-tight max-w-[24ch]">
            Three cartridges, three price tiers, one verdict.
          </h2>
        </div>
        <div class="flex flex-col md:items-end gap-2">
          <a href="/products" class="font-mono text-[11.5px] tracking-[0.08em] uppercase text-ink-900 border-b border-terracotta-500 pb-0.5 no-underline hover:text-terracotta-600 whitespace-nowrap">
            All products →
          </a>
          <p class="text-xs text-ink-500 max-w-[30ch] text-right">Price-history via Keepa · cross-checked weekly · raw data on methodology page.</p>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {compareRow.map((p, i) => (
          <div class="relative">
            {i === 1 && <span class="absolute z-10 top-3 left-3 bg-terracotta-500 text-white font-mono text-[10px] tracking-[0.14em] uppercase px-2.5 py-1 rounded">Best value</span>}
            {i === 0 && <span class="absolute z-10 top-3 left-3 bg-ink-900 text-cream-50 font-mono text-[10px] tracking-[0.14em] uppercase px-2.5 py-1 rounded">Budget pick</span>}
            {i === 2 && <span class="absolute z-10 top-3 left-3 bg-blue-900 text-cream-50 font-mono text-[10px] tracking-[0.14em] uppercase px-2.5 py-1 rounded">OEM quality</span>}
            <ProductCard product={p} />
          </div>
        ))}
      </div>
    </section>
  )}

  {/* ════ 7. ABOUT ════ */}
  <section class="relative bg-ink-900 text-cream-50 py-24 overflow-hidden">
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none
         bg-[radial-gradient(50%_60%_at_16%_50%,rgba(30,58,138,.3),transparent_70%)]"></div>
