---
import CompliantLayout from '@/layouts/CompliantLayout.astro';
import PageHero from '@/components/PageHero.astro';
import { getCollection } from 'astro:content';
import home from '@/data/spawn-home.json';

const allArticles = await getCollection('articles', ({ data }) => data.status === 'published');
const defaultAuthorSlug = (home as { defaultAuthorSlug?: string }).defaultAuthorSlug || 'marcus-inkledger';

const articleData = allArticles.map((a) => ({
  slug: a.slug,
  title: a.data.title,
  excerpt: (a.data as { excerpt?: string }).excerpt || '',
  heroImage: a.data.heroImage || '',
  author: a.data.author ?? defaultAuthorSlug,
  subtopic: (a.data as { subtopic?: string }).subtopic || '',
  updatedAt: a.data.updatedAt ? new Date(a.data.updatedAt).toISOString() : '',
  publishedAt: a.data.publishedAt ? new Date(a.data.publishedAt).toISOString() : '',
}));

const subtopicLabels: Record<string, string> = {
  cartridges: 'Cartridges',
  fix: 'Fix & Troubleshoot',
  printers: 'Printers',
  toner: 'Toner',
};
const description = 'Printer cartridges, toner, and ink alternatives — independent tests and weekly price context.';
---

<CompliantLayout title="Articles" description={description}>
  <PageHero
    eyebrow="The desk"
    title="Articles & investigations"
    description={description}
  />

  <section class="max-w-site mx-auto px-4 sm:px-5 pb-16 md:pb-20">
    <div class="flex flex-wrap gap-3 mb-8 items-center">
      <div class="flex flex-wrap gap-2" id="filter-bar">
        <button
          data-filter="all"
          class="filter-btn active px-4 py-1.5 rounded-full text-sm font-medium border border-cream-200 bg-ink-900 text-white transition-colors cursor-pointer"
        >All</button>
        {Object.entries(subtopicLabels).map(([slug, label]) => (
          <button
            data-filter={slug}
            class="filter-btn px-4 py-1.5 rounded-full text-sm font-medium border border-cream-200 bg-white text-ink-700 hover:border-terracotta-400 transition-colors cursor-pointer"
          >{label}</button>
        ))}
      </div>
      <div class="ml-auto">
        <select id="sort-select" class="text-sm border border-cream-200 rounded-full px-3 py-1.5 bg-white text-ink-700 cursor-pointer">
          <option value="newest">Newest first</option>
          <option value="oldest">Oldest first</option>
          <option value="az">A → Z</option>
          <option value="za">Z → A</option>
        </select>
      </div>
    </div>

    <p id="result-count" class="text-sm text-ink-500 mb-6"></p>

    <div id="articles-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {articleData.map((a) => (
        <a
          href={`/articles/${a.slug}`}
          data-subtopic={a.subtopic}
          data-title={a.title.toLowerCase()}
          data-date={a.updatedAt || a.publishedAt || '2026-01-01'}
          class="article-card group no-underline block card-soft overflow-hidden cursor-pointer hover:translate-y-0"
        >
          {a.heroImage ? (
            <div class="aspect-[16/10] overflow-hidden bg-cream-100">
              <img
                src={a.heroImage}
                alt=""
                loading="lazy"
                class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300"
              />
            </div>
          ) : (
            <div class="aspect-[16/10] bg-cream-100"></div>
          )}
          <div class="p-5">
            {a.subtopic && (
              <span class="inline-block text-xs font-medium text-terracotta-600 bg-terracotta-500/10 rounded-full px-2.5 py-0.5 mb-2">
                {subtopicLabels[a.subtopic] || a.subtopic}
              </span>
            )}
            <h2 class="font-display text-xl text-ink-900 !mt-0 leading-snug group-hover:text-terracotta-600 transition-colors">
              {a.title}
            </h2>
            {a.excerpt && <p class="text-ink-600 mt-2 text-sm line-clamp-2">{a.excerpt}</p>}
            {(a.updatedAt || a.publishedAt) && (
              <p class="mt-3 text-xs text-ink-500 font-mono uppercase tracking-wide">
                {new Date(a.updatedAt || a.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </p>
            )}
          </div>
        </a>
      ))}
    </div>

    <p id="no-results" class="hidden text-ink-600 text-center py-12">No articles match this filter.</p>
  </section>
</CompliantLayout>

<script>
  (function () {
    const grid    = document.getElementById('articles-grid');
    const noRes   = document.getElementById('no-results');
    const counter = document.getElementById('result-count');
    const cards   = Array.from(document.querySelectorAll('.article-card')) as HTMLElement[];
    const sortSel = document.getElementById('sort-select') as HTMLSelectElement;

    let activeFilter = 'all';
    let activeSort   = 'newest';

    function applyFilterSort() {
      const visible = cards.filter(c => activeFilter === 'all' || c.dataset.subtopic === activeFilter);

      visible.sort((a, b) => {
        if (activeSort === 'newest') return (b.dataset.date || '').localeCompare(a.dataset.date || '');
        if (activeSort === 'oldest') return (a.dataset.date || '').localeCompare(b.dataset.date || '');
        if (activeSort === 'az')     return (a.dataset.title || '').localeCompare(b.dataset.title || '');
        if (activeSort === 'za')     return (b.dataset.title || '').localeCompare(a.dataset.title || '');
        return 0;
      });

      cards.forEach(c => { c.style.display = 'none'; });
      visible.forEach(c => { c.style.display = ''; grid?.appendChild(c); });

      noRes?.classList.toggle('hidden', visible.length > 0);
      if (counter) counter.textContent = visible.length === cards.length
        ? `${cards.length} articles`
        : `${visible.length} of ${cards.length} articles`;
    }

    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        activeFilter = (btn as HTMLElement).dataset.filter || 'all';
        document.querySelectorAll('.filter-btn').forEach(b => {
          b.classList.remove('active', 'bg-ink-900', 'text-white');
          b.classList.add('bg-white', 'text-ink-700');
        });
        btn.classList.add('active', 'bg-ink-900', 'text-white');
        btn.classList.remove('bg-white', 'text-ink-700');
        applyFilterSort();
      });
    });

    sortSel?.addEventListener('change', () => { activeSort = sortSel.value; applyFilterSort(); });

    applyFilterSort();
  })();
</script>
