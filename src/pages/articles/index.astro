---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles', ({ data }) => data.status === 'published');
const sorted = articles.sort((a, b) => +new Date(b.data.publishedAt) - +new Date(a.data.publishedAt));

const POOL = [
  'https://images.unsplash.com/photo-1588196749597-9ff075ee6b5b?auto=format&fit=crop&w=800&q=80',
  'https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=800&q=80',
  'https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?auto=format&fit=crop&w=800&q=80',
  'https://images.unsplash.com/photo-1607082348824-0a96f2a4b9da?auto=format&fit=crop&w=800&q=80',
  'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&w=800&q=80',
  'https://images.unsplash.com/photo-1563986768494-4dee2763ff3f?auto=format&fit=crop&w=800&q=80',
  'https://images.unsplash.com/photo-1542744095-fcf48d80b0fd?auto=format&fit=crop&w=800&q=80',
  'https://images.unsplash.com/photo-1556761175-5973dc0f32e7?auto=format&fit=crop&w=800&q=80',
  'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=800&q=80',
  'https://images.unsplash.com/photo-1579548122080-c35fd6820ecb?auto=format&fit=crop&w=800&q=80',
  'https://images.unsplash.com/photo-1612817159949-195b6eb9e31a?auto=format&fit=crop&w=800&q=80',
  'https://images.unsplash.com/photo-1557804506-669a67965ba0?auto=format&fit=crop&w=800&q=80',
];
const hashSlug = (s: string) => { let h=0; for(let i=0;i<s.length;i++) h=((h<<5)-h+s.charCodeAt(i))|0; return Math.abs(h); };
const poolImage = (slug: string) => POOL[hashSlug(slug) % POOL.length];

const tagCounts = new Map<string,number>();
for (const a of sorted) for (const t of (a.data.tags??[])) tagCounts.set(t,(tagCounts.get(t)||0)+1);
const topTags = [...tagCounts.entries()].sort((a,b)=>b[1]-a[1]).slice(0,8).map(([t])=>t);

const cards = sorted.map(a => ({ entry: a, imageUrl: a.data.heroImage || poolImage(a.slug) }));
---

<BaseLayout title="Articles | InkLedger" description="Ink cartridge guides, cost-per-page analysis, and printer savings for home and office.">
  <section class="max-w-6xl mx-auto px-5 py-12">

    <div class="mb-8">
      <h1 class="font-display text-4xl text-ink-900 mb-3">Articles</h1>
      <p class="text-ink-700 max-w-prose">
        Ink cost guides, cartridge comparisons, refill tutorials, and print-quality tests — everything you need to stop overpaying.
      </p>
    </div>

    {topTags.length > 0 && (
      <div id="il-tag-strip" class="flex flex-wrap gap-2 mb-8">
        <button data-tag="all" class="il-pill il-pill-active px-4 py-1.5 rounded-full text-sm font-medium border transition-colors duration-150">
          All · {sorted.length}
        </button>
        {topTags.map(tag => (
          <button data-tag={tag} class="il-pill px-4 py-1.5 rounded-full text-sm font-medium border border-slate-300 text-slate-700 bg-white hover:border-blue-700 hover:text-blue-800 transition-colors duration-150">
            {tag.replace(/-/g,' ')} · {tagCounts.get(tag)}
          </button>
        ))}
      </div>
    )}

    {sorted.length === 0 && <p class="text-ink-700">First articles coming soon.</p>}

    <div id="il-article-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {cards.map(({ entry: a, imageUrl }) => (
        <a href={`/articles/${a.slug}`} class="il-card group no-underline block" data-tags={(a.data.tags??[]).join(',')}>
          <div class="rounded-xl overflow-hidden mb-3 aspect-[16/10]">
            <img src={imageUrl} alt={a.data.title} loading="lazy"
              class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300" />
          </div>
          <h2 class="font-display text-xl text-ink-900 !mt-0 leading-snug group-hover:text-blue-800 transition-colors">
            {a.data.title}
          </h2>
          {a.data.excerpt && <p class="text-ink-700 mt-2 text-sm line-clamp-2">{a.data.excerpt}</p>}
          <p class="text-slate-500 text-xs mt-2">
            {new Date(a.data.publishedAt).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}
          </p>
        </a>
      ))}
    </div>

  </section>
</BaseLayout>

<style>
  .il-pill-active { background-color:#1e3a8a; border-color:#1e3a8a; color:#fff; }
  .il-card[hidden] { display:none; }
</style>

<script>
  (function(){
    const strip = document.getElementById('il-tag-strip');
    const grid  = document.getElementById('il-article-grid');
    if(!strip||!grid) return;
    const pills = strip.querySelectorAll<HTMLButtonElement>('.il-pill');
    const cards = grid.querySelectorAll<HTMLElement>('.il-card');
    function activate(tag:string){
      pills.forEach(p=>{
        const on = p.dataset.tag===tag;
        p.classList.toggle('il-pill-active',on);
        p.classList.toggle('border-slate-300',!on);
        p.classList.toggle('text-slate-700',!on);
        p.classList.toggle('bg-white',!on);
      });
      cards.forEach(c=>{ c.hidden = tag!=='all' && !(c.dataset.tags||'').split(',').includes(tag); });
    }
    pills.forEach(p=>p.addEventListener('click',()=>activate(p.dataset.tag||'all')));
  })();
</script>
