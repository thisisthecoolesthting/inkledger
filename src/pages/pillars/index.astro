---
import CompliantLayout from '@/layouts/CompliantLayout.astro';
import PageHero from '@/components/PageHero.astro';
import { getCollection } from 'astro:content';
import home from '@/data/spawn-home.json';

const b = home.brand;
const pillars = await getCollection('pillars', ({ data }) => data.status === 'published');
const featuredSlugs = ['ink-pricing-report', 'refill-guide'];
const featured = featuredSlugs
  .map((slug) => pillars.find((p) => p.slug === slug))
  .filter(Boolean);
const rest = pillars
  .filter((p) => !featuredSlugs.includes(p.slug))
  .sort((a, b) => +new Date(b.data.publishedAt) - +new Date(a.data.publishedAt));
const sorted = [...featured, ...rest];
---

<CompliantLayout
  title="Guides"
  description="Long-form InkLedger authority guides on ink pricing, refills, compatibles, and printer cost of ownership."
>
  <PageHero
    eyebrow="Authority guides"
    title="Pillars we track every week"
    description="Explainer → tracked models → cheaper alternative. Three clicks from question to answer, with retail pricing kept current."
  />

  <section class="max-w-site mx-auto px-4 sm:px-5 pb-16 md:pb-20">
    {sorted.length === 0 && (
      <p class="text-ink-600">First guides coming soon.</p>
    )}

    <div class="grid md:grid-cols-2 gap-6">
      {sorted.map((p, idx) => (
        <a
          href={`/pillars/${p.slug}`}
          class="card-soft overflow-hidden no-underline group cursor-pointer"
        >
          {p.data.heroImage ? (
            <div class="aspect-[16/9] overflow-hidden bg-cream-100">
              <img
                src={p.data.heroImage}
                alt=""
                loading="lazy"
                class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300"
              />
            </div>
          ) : (
            <div class="aspect-[16/9] bg-gradient-to-br from-blue-900 to-ink-900"></div>
          )}
          <div class="p-6">
            {idx < 2 && (
              <span class="inline-block font-mono text-[10px] tracking-[0.14em] uppercase text-terracotta-600 bg-terracotta-500/10 rounded-full px-2.5 py-1 mb-3">
                Flagship guide
              </span>
            )}
            <h2 class="font-display text-2xl text-ink-900 !mt-0 group-hover:text-terracotta-600 transition-colors">
              {p.data.title}
            </h2>
            <p class="text-ink-600 mt-2 text-base leading-relaxed">{p.data.excerpt}</p>
            <p class="text-ink-500 text-xs mt-4 font-mono tracking-wide uppercase">
              Updated {new Date(p.data.updatedAt ?? p.data.publishedAt).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
            </p>
          </div>
        </a>
      ))}
    </div>
  </section>
</CompliantLayout>
