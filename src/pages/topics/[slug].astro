---
import BaseLayout from '@/layouts/BaseLayout.astro';
import menu from '@/data/menu.json';
import { getCollection } from 'astro:content';
import home from '@/data/spawn-home.json';

export async function getStaticPaths() {
  return menu.subtopics.map((st) => ({
    params: { slug: st.slug },
    props: { subtopic: st },
  }));
}

const { subtopic } = Astro.props;
const allArticles = await getCollection('articles', ({ data }) => data.status !== 'draft');

// Match by frontmatter subtopic field OR keyword overlap in title/tags
const articles = allArticles.filter((a) => {
  if ((a.data as any).subtopic === subtopic.slug) return true;
  const haystack = [a.data.title, ...(a.data.tags ?? [])].join(' ').toLowerCase();
  return subtopic.match.some((kw: string) => haystack.includes(kw.toLowerCase()));
}).sort((a, b) => new Date((b.data as any).pubDate ?? 0).getTime() - new Date((a.data as any).pubDate ?? 0).getTime());

const b = home.brand;
const siteName = (b as any).name ?? b.fullName;
const title = `${subtopic.label} — ${siteName}`;
const description = `Browse all ${subtopic.label.toLowerCase()} articles on ${siteName}.`;
---

<BaseLayout title={title} description={description}>
  <div class="container-prose py-12 md:py-16">
    <header class="mb-10">
      <p class="text-sm font-medium text-terracotta-500 uppercase tracking-wider mb-2">{menu.main}</p>
      <h1 class="font-display text-3xl md:text-4xl text-ink-900">{subtopic.label}</h1>
      <p class="mt-3 text-ink-600">{articles.length} article{articles.length !== 1 ? 's' : ''}</p>
    </header>

    {articles.length === 0 ? (
      <p class="text-ink-500">No articles yet — check back soon.</p>
    ) : (
      <ul class="space-y-6">
        {articles.map((article) => (
          <li class="border-b border-cream-200 pb-6 last:border-0">
            <a href={`/articles/${article.slug}/`} class="group no-underline">
              <h2 class="font-semibold text-lg text-ink-900 group-hover:text-terracotta-600 transition-colors mb-1">
                {article.data.title}
              </h2>
              {(article.data as any).description && (
                <p class="text-sm text-ink-600 line-clamp-2">{(article.data as any).description}</p>
              )}
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</BaseLayout>
