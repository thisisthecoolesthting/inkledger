---
import CompliantLayout from '@/layouts/CompliantLayout.astro';
import PageHero from '@/components/PageHero.astro';
import ProductCard from '@/components/ProductCard.astro';
import { getCollection } from 'astro:content';
import home from '@/data/spawn-home.json';

const products = await getCollection('products', ({ data }) => data.status === 'published');

const complete = products.filter((p) => {
  const d = p.data;
  const hasImage = d.imageUrl && !d.imageUrl.includes('example') && !d.imageUrl.startsWith('data:');
  const hasPrice = typeof d.price === 'number' && d.price > 0;
  const hasRating = typeof d.rating === 'number' && d.rating > 0;
  return hasImage && hasPrice && hasRating;
});

const sorted = complete.sort((a, b) => (b.data.score ?? 0) - (a.data.score ?? 0));

const byCategory = sorted.reduce<Record<string, typeof sorted>>((acc, p) => {
  const cat = p.data.category || 'other';
  (acc[cat] = acc[cat] || []).push(p);
  return acc;
}, {});
---

<CompliantLayout
  title="Product reviews"
  description="Independent printer ink, toner, and refill reviews with cost-per-page scores and weekly price checks."
>
  <PageHero
    eyebrow="Tracked this week"
    title="Cartridges and refills we would buy"
    description="Every listing passes a display bar: real image, live price, verified rating, and hands-on or lab yield context. Commission never changes rank order."
  />

  <section class="max-w-site mx-auto px-4 sm:px-5 pb-16 md:pb-20">
    <p class="text-sm text-ink-500 mb-10">
      {sorted.length} products scored · sorted by InkLedger value score ·
      {' '}
      <a href="/methodology/" class="text-terracotta-600 no-underline hover:underline">How we test →</a>
    </p>

    {Object.entries(byCategory).map(([cat, items]) => (
      <section class="mb-14">
        <h2 class="font-display text-2xl text-ink-900 capitalize mb-5">{cat.replace(/-/g, ' ')}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
          {items.map((p) => <ProductCard product={p} />)}
        </div>
      </section>
    ))}
  </section>
</CompliantLayout>
